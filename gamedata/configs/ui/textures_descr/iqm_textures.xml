<w>
	<!-- IQM ships its own solid-white texture so its tinted card/line/node draw
	     correctly with no dependency on any other mod. iqm_white_box is a solid
	     white region (tint it in script via SetTextureColor). -->
	<file name="ui\iqm_ui">
		<texture id="iqm_white_box" x="174" y="0" width="174" height="60" />
	</file>

	<!-- White anti-aliased filled circle (alpha carries the shape, RGB is white so
	     tinting stays clean). Used for the head node; a larger black copy behind it
	     forms the border ring. -->
	<file name="ui\iqm_circle">
		<texture id="iqm_circle" x="0" y="0" width="64" height="64" />
	</file>

	<!-- Soft gaussian halo drawn behind the node dot (glow). White RGB, radial
	     alpha falloff; tinted the accent colour at low alpha in script. -->
	<file name="ui\iqm_glow">
		<texture id="iqm_glow" x="0" y="0" width="128" height="128" />
	</file>

	<!-- Soft-edged slab stretched under the card as a whole-card drop shadow.
	     White RGB, feathered alpha; tinted black at low alpha in script. -->
	<file name="ui\iqm_shadow">
		<texture id="iqm_shadow" x="0" y="0" width="64" height="64" />
	</file>

	<!-- Role glyphs for the ambient service/important cards, as a 4x2 grid of 128px
	     cells (Tabler outline icons, white stroke on transparent so SetTextureColor
	     tints them the accent colour). Bundled, so the role cards need no other mod. -->
	<file name="ui\iqm_roles">
		<texture id="iqm_role_trader"    x="0"   y="0"   width="128" height="128" />
		<texture id="iqm_role_mechanic"  x="128" y="0"   width="128" height="128" />
		<texture id="iqm_role_barman"    x="256" y="0"   width="128" height="128" />
		<texture id="iqm_role_medic"     x="384" y="0"   width="128" height="128" />
		<texture id="iqm_role_guide"     x="0"   y="128" width="128" height="128" />
		<texture id="iqm_role_important" x="128" y="128" width="128" height="128" />
		<texture id="iqm_role_work"      x="256" y="128" width="128" height="128" />
	</file>

	<!-- Both card plates are a single rounded-rect quad (white with a faint top-down
	     luminance gradient, tinted the charcoal plate colour in script; alpha carries
	     the rounded shape). One quad means no slice seams, which at fractional UI
	     scaling would round to a 1px gap or overlap and show as a thin line. iqm_chip
	     is the near-square icon chip; iqm_plate is the wider text card. -->
	<file name="ui\iqm_chip">
		<texture id="iqm_chip" x="0" y="0" width="128" height="96" />
	</file>
	<file name="ui\iqm_plate">
		<texture id="iqm_plate" x="0" y="0" width="192" height="48" />
	</file>
</w>
